root = true

[*]
indent_style = space
indent_size = 4
charset = utf-8
end_of_line = lf
trim_trailing_whitespace = true
insert_final_newline = true

[*.go]
indent_style = tab

[*.dart]
indent_size = 2
max_line_length = 80

[*.java]
indent_size = 4
max_line_length = 100

[*.kt]
indent_size = 4
max_line_length = 100

[*.xml]
indent_size = 2

[*.yaml]
indent_size = 2

[*.json]
indent_size = 2

[*.properties]
indent_style = space
indent_size = 2

[*.md]
trim_trailing_whitespace = false
max_line_length = off
